# Copy this to .streamlit/secrets.toml for local dev,
# or paste each key into the Streamlit Cloud Secrets UI (Settings → Secrets).

ANTHROPIC_API_KEY = "sk-ant-..."

# Spotify (enricher + profile photos)
SPOTIFY_CLIENT_ID = ""
SPOTIFY_CLIENT_SECRET = ""

# Profile generation backend: "claude" (default) or "ollama" (local only)
PROFILE_BACKEND = "claude"

# Neo4j — persistent swipe storage + artist graph across Streamlit Cloud restarts
# URI is auto-derived if NEO4J_USER is an 8-char Aura instance ID
NEO4J_URI      = "neo4j+s://<instance-id>.databases.neo4j.io"
NEO4J_USER     = "<instance-id>"
NEO4J_PASSWORD = ""   # paste your Aura password here

# Discogs
DISCOGS_KEY    = ""
DISCOGS_SECRET = ""

# YouTube Data API v3
YOUTUBE_API_KEY = ""

# Mixcloud
MIXCLOUD_CLIENT_ID     = ""
MIXCLOUD_CLIENT_SECRET = ""
